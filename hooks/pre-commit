#!/usr/bin/env bash
# Git pre-commit hook: 提交前自动清理和检查
# Windows环境请使用: python hooks/pre-commit.py

# 检测操作系统
if [[ "$OSTYPE" == "msys" || "$OSTYPE" == "win32" ]]; then
    # Windows: 调用Python脚本
    python hooks/pre-commit.py
    exit $?
fi

# Unix/Linux/Mac: 使用bash实现
set -e

echo "=========================================="
echo "Git Pre-Commit Hook - 自动检查与清理"
echo "=========================================="

# 1. 自动清理临时文件
echo ""
echo "[1/3] 清理临时文件..."
python scripts/clean_temp_files.py
if [ $? -ne 0 ]; then
    echo "[ERROR] 清理失败"
    exit 1
fi

# 2. 检查Python语法错误
echo ""
echo "[2/3] 检查Python语法..."
python -m py_compile core/*.py config/*.py generate_report.py 2>/dev/null
if [ $? -ne 0 ]; then
    echo "[ERROR] Python语法检查失败"
    exit 1
fi
echo "[OK] Python语法检查通过"

# 3. 运行健康检查（轻量版）
echo ""
echo "[3/3] 快速健康检查..."
python generate_report.py doctor > /dev/null 2>&1
if [ $? -ne 0 ]; then
    echo "[WARN] 依赖包检查失败，但允许提交"
else
    echo "[OK] 依赖包检查通过"
fi

echo ""
echo "=========================================="
echo "[OK] Pre-commit 检查全部通过，准备提交"
echo "=========================================="

exit 0
